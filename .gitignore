# WhatsApp Web (wppconnect) saved session — contains the admin's logged-in
# tokens for whatsapp.com plus puppeteer's chromium user data. Must NOT be
# committed: it's huge, machine-specific, and a security risk if leaked.
apps/backend/tokens/

# Local uploads (multer-served customer/order images & audio)
apps/backend/uploads/

# dist-bundle runtime (WhatsApp bridge IPC + customer/order uploads) — never version.
# These held live customer phone numbers + order text on the public repo.
apps/backend/dist-bundle/uploads/
