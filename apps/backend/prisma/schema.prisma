// ============================================
// Tamem Delivery — Prisma Schema (MySQL)
// ============================================
// نموذج البيانات الكامل للمشروع. أي تغيير هنا = migration جديد.
// الملف يخص: أحمد كمال. تغييرات من خالد عبر issue.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum UserRole {
  CUSTOMER
  DRIVER
  MERCHANT
  ADMIN
}

enum DriverStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum ServiceCategory {
  DELIVERY
  SHIPPING
  MERCHANT
}

enum PricingMethod {
  FIXED
  DISTANCE
  WEIGHT
  DISTANCE_WEIGHT
  QUOTE
}

enum ServiceFieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  MULTISELECT
  IMAGE
  LOCATION
  DATE
  TIME
  BOOLEAN
  PHONE
}

/// The 12 order states — single source of truth in the system.
enum OrderStatus {
  NEW
  UNDER_REVIEW
  PRICED
  AWAITING_CUSTOMER_APPROVAL
  ACCEPTED
  DRIVER_ASSIGNED
  PICKED_UP
  IN_ROUTE
  DELIVERED
  COMPLETED
  CANCELLED
  REJECTED
}

enum SizeCategory {
  SMALL
  MEDIUM
  LARGE
}

enum SpeedTier {
  STANDARD
  EXPRESS
}

enum PaymentMethod {
  CASH
  VODAFONE_CASH
  INSTAPAY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationChannel {
  PUSH
  WHATSAPP
  IN_APP
}

enum NotificationType {
  ORDER_STATUS
  PROMO
  SYSTEM
  ALERT
}

enum AlertType {
  // Orders
  PENDING_ORDER                  // priced but customer never approved
  MERCHANT_NOT_ACCEPTING         // merchant didn't accept in window
  ORDER_STALE_IN_STAGE           // stuck in any stage too long
  DRIVER_NOT_ASSIGNED            // no driver within window
  DRIVER_PICKUP_LATE             // driver assigned but not picked up in window
  DRIVER_DELIVERY_LATE           // in route but not delivered in window
  // People / system
  DRIVER_NOT_RESPONDING          // BUSY but no location ping
  CASH_LIMIT_EXCEEDED            // driver carrying too much cash
  COMPLAINT                      // customer complaint
  // Payments
  PAYMENT_PENDING                // online payment never confirmed
  PAYMENT_FAILED                 // gateway returned error
  REFUND_REQUESTED               // customer asked for refund
  ORDER_CANCELLED_AFTER_PAY      // bad — refund flow blocked
  // System
  STATUS_UPDATE_ERROR            // backend failed to write a status change
}

/// Broad category — used for the dashboard filter chips and stats cards.
/// Each AlertType maps to exactly one category in code.
enum AlertCategory {
  ORDER
  PAYMENT
  DRIVER
  MERCHANT
  CUSTOMER
  COMPLAINT
  DELAY
  SYSTEM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED   // someone is working on it
  RESOLVED
  DISMISSED      // false positive / no action needed
  ESCALATED      // bumped to a supervisor
}

enum LinkType {
  SERVICE
  MERCHANT
  EXTERNAL
  NONE
}

// ============================================
// Core Users
// ============================================

model User {
  id              String   @id @default(cuid())
  phone           String   @unique
  passwordHash    String?
  name            String
  email           String?  @unique
  avatarUrl       String?
  role            UserRole @default(CUSTOMER)
  googleId        String?  @unique
  isPhoneVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  city            String?
  governorate     String?
  defaultAddress  String?  @db.VarChar(500)
  fcmToken        String?
  passwordResetHash     String?
  passwordResetExpiresAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  driverProfile   DriverProfile?
  merchantProfile MerchantProfile?
  customerOrders  Order[]          @relation("CustomerOrders")
  driverOrders    Order[]          @relation("DriverOrders")
  refreshTokens   RefreshToken[]
  notifications   Notification[]
  statusChanges   OrderStatusHistory[]
  resolvedAlerts  Alert[]          @relation("AlertResolver")
  confirmedPays   Payment[]        @relation("PaymentConfirmer")
  servicesCreated Service[]        @relation("ServiceCreator")
  savedAddresses  CustomerAddress[]
  recurringOrders RecurringOrder[] @relation("CustomerRecurring")

  @@index([role])
  @@index([phone])
}

/// Address book entries the customer can pick from when creating an order.
/// Cleaner than stuffing them into a JSON column — lets us index, soft-delete,
/// and reference them from Order later if needed.
model CustomerAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @db.VarChar(60)
  address   String   @db.VarChar(500)
  lat       Decimal? @db.Decimal(10, 7)
  lng       Decimal? @db.Decimal(10, 7)
  notes     String?  @db.VarChar(500)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isDefault])
}

model DriverProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          DriverStatus @default(OFFLINE)
  vehicleType     String
  vehiclePlate    String
  nationalId      String?
  licenseImageUrl String?
  currentLat      Decimal?     @db.Decimal(10, 7)
  currentLng      Decimal?     @db.Decimal(10, 7)
  lastLocationAt  DateTime?
  totalDeliveries Int          @default(0)
  totalEarnings   Decimal      @default(0) @db.Decimal(10, 2)
  cashOnHand      Decimal      @default(0) @db.Decimal(10, 2)
  rating          Decimal?     @db.Decimal(3, 2)
  governorate     String
  notes           String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([governorate])
}

/// Manual store status override. Falls back to BusinessHours-based auto-status
/// when set to OPEN (the default). TEMPORARILY_CLOSED keeps the merchant in
/// the directory but blocks new orders with a softer message than CLOSED.
enum MerchantStatus {
  OPEN
  CLOSED
  TEMPORARILY_CLOSED
}

model MerchantProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName    String
  storeNameAr  String
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  description  String?  @db.Text
  logoUrl      String?
  coverUrl     String?
  addressLine  String   @db.VarChar(500)
  lat          Decimal  @db.Decimal(10, 7)
  lng          Decimal  @db.Decimal(10, 7)
  governorate  String
  city         String
  /// Legacy free-text JSON — superseded by the structured BusinessHours rows
  /// below. Kept for backwards compat with older seeds.
  openHours    Json?
  /// Legacy quick toggle. Now derived from `manualStatus` + business hours.
  isOpen       Boolean  @default(true)
  /// Admin/merchant manual override. OPEN = use business hours. CLOSED /
  /// TEMPORARILY_CLOSED = block orders regardless of schedule.
  manualStatus MerchantStatus @default(OPEN)
  /// IANA timezone for hour resolution. Egypt is Africa/Cairo by default.
  timezone     String   @default("Africa/Cairo") @db.VarChar(60)
  /// Default commission percentage Tamem takes from orders at this merchant.
  /// e.g. 15 = 15%. Falls back to the platform-wide setting when null.
  commissionPct Decimal? @db.Decimal(5, 2)
  rating       Decimal? @db.Decimal(3, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products      Product[]
  businessHours MerchantBusinessHours[]

  @@index([categoryId])
  @@index([governorate])
  @@index([isOpen])
  @@index([manualStatus])
}

/// Per-weekday opening windows for a merchant. One row per (merchant, dayOfWeek)
/// with a multi-window day modeled as 2+ rows (lunch break, late-night, etc).
///
///   dayOfWeek:  0=Sunday .. 6=Saturday (matches JS Date.getDay())
///   openMin:    minutes since midnight in the merchant's local timezone
///   closeMin:   same, must be > openMin. For after-midnight (e.g. close at
///               02:00 next day), use 1440+actual e.g. 1560 for 02:00.
///   isClosed:   when true, the merchant is closed all day on dayOfWeek
///               (overrides any window rows for that day).
model MerchantBusinessHours {
  id         String          @id @default(cuid())
  merchantId String
  merchant   MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  dayOfWeek  Int             @db.TinyInt
  openMin    Int             @db.SmallInt
  closeMin   Int             @db.SmallInt
  isClosed   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([merchantId, dayOfWeek])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  iconUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  merchants MerchantProfile[]
}

// ============================================
// Dynamic Services — the centerpiece
// ============================================

model Service {
  id                         String          @id @default(cuid())
  key                        String          @unique
  name                       String
  nameAr                     String
  category                   ServiceCategory
  imageUrl                   String?
  iconUrl                    String?
  description                String?         @db.Text
  descriptionAr              String?         @db.Text
  pricingMethod              PricingMethod
  basePrice                  Decimal?        @db.Decimal(10, 2)
  pricePerKm                 Decimal?        @db.Decimal(10, 2)
  pricePerKg                 Decimal?        @db.Decimal(10, 2)
  requiresPickupLocation     Boolean         @default(false)
  requiresDeliveryLocation   Boolean         @default(true)
  requiresImageUpload        Boolean         @default(false)
  allowsTextNote             Boolean         @default(true)
  supportsMultiplePickups    Boolean         @default(false)
  supportsMultipleDeliveries Boolean         @default(false)
  sortOrder                  Int             @default(0)
  isActive                   Boolean         @default(true)
  createdById                String?
  createdBy                  User?           @relation("ServiceCreator", fields: [createdById], references: [id])
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  fields           ServiceField[]
  orders           Order[]
  rules            PricingRule[]
  recurringOrders  RecurringOrder[]

  @@index([category, isActive])
}

model ServiceField {
  id            String           @id @default(cuid())
  serviceId     String
  service       Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  key           String
  label         String
  labelAr       String
  type          ServiceFieldType
  isRequired    Boolean          @default(false)
  sortOrder     Int              @default(0)
  options       Json?
  validation    Json?
  placeholder   String?
  placeholderAr String?
  helpText      String?          @db.Text
  helpTextAr    String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([serviceId, key])
  @@index([serviceId, sortOrder])
}

// ============================================
// Orders — heart of the system
// ============================================

model Order {
  id                  String          @id @default(cuid())
  orderNumber         String          @unique
  serviceId           String
  service             Service         @relation(fields: [serviceId], references: [id])
  customerId          String
  customer            User            @relation("CustomerOrders", fields: [customerId], references: [id])
  category            ServiceCategory
  status              OrderStatus     @default(NEW)
  merchantId          String?
  assignedDriverId    String?
  assignedDriver      User?           @relation("DriverOrders", fields: [assignedDriverId], references: [id])
  customData          Json?
  notes               String?         @db.Text
  imageUrls           Json?

  // single-point fields (DELIVERY + SHIPPING)
  pickupLat           Decimal?        @db.Decimal(10, 7)
  pickupLng           Decimal?        @db.Decimal(10, 7)
  pickupAddress       String?         @db.VarChar(500)
  deliveryLat         Decimal?        @db.Decimal(10, 7)
  deliveryLng         Decimal?        @db.Decimal(10, 7)
  deliveryAddress     String?         @db.VarChar(500)

  // shipping-specific
  weightKg            Decimal?        @db.Decimal(8, 2)
  sizeCategory        SizeCategory?
  isFragile           Boolean?        @default(false)
  speedTier           SpeedTier?      @default(STANDARD)
  estimatedDistanceKm Decimal?        @db.Decimal(8, 2)

  // pricing + discounts
  quotedPrice         Decimal?        @db.Decimal(10, 2)
  finalPrice          Decimal?        @db.Decimal(10, 2)
  currency            String          @default("EGP")
  couponCode          String?         @db.VarChar(40)
  discountAmount      Decimal?        @db.Decimal(10, 2)
  walletUsed          Decimal?        @db.Decimal(10, 2)
  /// Breakdown for the accountant report. All optional because legacy orders
  /// won't have them. The convention:
  ///   merchantSubtotal  = sum of items the merchant gets credit for
  ///   deliveryFee       = what the customer pays for the ride
  ///   platformCommission= what Tamem keeps (typically a % of merchantSubtotal)
  ///   merchantPayout    = merchantSubtotal - platformCommission
  /// finalPrice = merchantSubtotal + deliveryFee - discountAmount - walletUsed
  merchantSubtotal    Decimal?        @db.Decimal(10, 2)
  deliveryFee         Decimal?        @db.Decimal(10, 2)
  platformCommission  Decimal?        @db.Decimal(10, 2)
  merchantPayout      Decimal?        @db.Decimal(10, 2)

  // payment
  paymentMethod       PaymentMethod?
  paymentStatus       PaymentStatus   @default(PENDING)

  // scheduling — non-null = customer wants this delivered at this future time
  scheduledFor        DateTime?

  // manual flag — orders created by admin from dashboard (phone-in orders)
  createdByAdminId    String?

  // timestamps for lifecycle
  customerApprovedAt  DateTime?
  pickedUpAt          DateTime?
  deliveredAt         DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?         @db.VarChar(500)
  whatsappSentAt      DateTime?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  items               OrderItem[]
  pickupPoints        OrderPickupPoint[]
  deliveryPoints      OrderDeliveryPoint[]
  statusHistory       OrderStatusHistory[]
  payments            Payment[]
  alerts              Alert[]
  review              OrderReview?
  couponRedemption    CouponRedemption?

  @@index([status, createdAt(sort: Desc)])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([assignedDriverId, status])
  @@index([category])
  @@index([serviceId])
}

/// One review per completed order. Customer rates the experience overall and
/// optionally the driver / merchant separately. We recompute the driver's and
/// merchant's running average ratings whenever a review is created.
model OrderReview {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId    String
  driverId      String?
  merchantId    String?
  rating        Int      // 1..5, overall order experience
  driverRating  Int?     // 1..5, optional
  merchantRating Int?    // 1..5, optional
  comment       String?  @db.VarChar(1000)
  createdAt     DateTime @default(now())

  @@index([driverId])
  @@index([merchantId])
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product? @relation(fields: [productId], references: [id])
  productNameSnapshot String
  unitPriceSnapshot   Decimal? @db.Decimal(10, 2)
  quantity            Int
  merchantId          String?
  pickupPointId       String?
  pickupPoint         OrderPickupPoint? @relation(fields: [pickupPointId], references: [id])
  notes               String?  @db.VarChar(500)

  @@index([orderId])
  @@index([productId])
}

model OrderPickupPoint {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sortOrder     Int       @default(0)
  merchantId    String?
  label         String?
  address       String    @db.VarChar(500)
  lat           Decimal   @db.Decimal(10, 7)
  lng           Decimal   @db.Decimal(10, 7)
  contactName   String?
  contactPhone  String?
  notes         String?   @db.VarChar(500)
  arrivedAt     DateTime?
  pickedUpAt    DateTime?
  items         OrderItem[]

  @@index([orderId])
}

model OrderDeliveryPoint {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sortOrder      Int       @default(0)
  recipientName  String
  recipientPhone String
  address        String    @db.VarChar(500)
  lat            Decimal   @db.Decimal(10, 7)
  lng            Decimal   @db.Decimal(10, 7)
  notes          String?   @db.VarChar(500)
  deliveredAt    DateTime?
  proofImageUrl  String?

  @@index([orderId])
}

model OrderStatusHistory {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus    OrderStatus?
  toStatus      OrderStatus
  changedById   String
  changedBy     User        @relation(fields: [changedById], references: [id])
  changedByRole UserRole
  reason        String?     @db.VarChar(500)
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([orderId, createdAt])
}

// ============================================
// Products (merchant catalogs)
// ============================================

model Product {
  id          String          @id @default(cuid())
  merchantId  String
  merchant    MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name        String
  nameAr      String
  description String?         @db.Text
  imageUrl    String?
  price       Decimal         @db.Decimal(10, 2)
  unit        String?
  isAvailable Boolean         @default(true)
  stock       Int?
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  orderItems  OrderItem[]

  @@index([merchantId, isAvailable])
}

// ============================================
// Pricing rules (admin-tunable)
// ============================================

model PricingRule {
  id                 String   @id @default(cuid())
  serviceId          String
  service            Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  governorate        String?
  city               String?
  basePrice          Decimal  @default(0) @db.Decimal(10, 2)
  pricePerKm         Decimal  @default(0) @db.Decimal(10, 2)
  pricePerKg         Decimal  @default(0) @db.Decimal(10, 2)
  minPrice           Decimal  @default(0) @db.Decimal(10, 2)
  maxPrice           Decimal? @db.Decimal(10, 2)
  fragileSurcharge   Decimal  @default(0) @db.Decimal(10, 2)
  expressSurcharge   Decimal  @default(0) @db.Decimal(10, 2)
  weekendMultiplier  Decimal? @db.Decimal(5, 2)
  nightMultiplier    Decimal? @db.Decimal(5, 2)
  nightStartHour     Int?
  nightEndHour       Int?
  isActive           Boolean  @default(true)
  effectiveFrom      DateTime?
  effectiveTo        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([serviceId, isActive])
  @@index([governorate])
}

// ============================================
// Payments
// ============================================

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceNumber String?
  proofImageUrl   String?
  confirmedById   String?
  confirmedBy     User?         @relation("PaymentConfirmer", fields: [confirmedById], references: [id])
  confirmedAt     DateTime?
  notes           String?       @db.VarChar(500)
  createdAt       DateTime      @default(now())

  // refund tracking — set when admin reverses a confirmed payment
  refundedAt      DateTime?
  refundedById    String?
  refundAmount    Decimal?      @db.Decimal(10, 2)
  refundReason    String?       @db.VarChar(500)

  @@index([orderId])
  @@index([status])
}

// ============================================
// Notifications & Alerts
// ============================================

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  titleAr   String
  body      String              @db.Text
  bodyAr    String              @db.Text
  data      Json?
  channel   NotificationChannel @default(IN_APP)
  isRead    Boolean             @default(false)
  sentAt    DateTime            @default(now())
  readAt    DateTime?

  @@index([userId, isRead, sentAt(sort: Desc)])
}

model Alert {
  id               String         @id @default(cuid())
  type             AlertType
  category         AlertCategory  @default(SYSTEM)
  severity         AlertSeverity  @default(MEDIUM)
  status           AlertStatus    @default(OPEN)
  title            String
  titleAr          String
  description      String         @db.Text
  descriptionAr    String         @db.Text
  relatedOrderId   String?
  relatedOrder     Order?         @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  relatedUserId    String?
  /// Stable key for deduplication. Pattern: `{type}:{orderId|userId}:{trigger}`.
  /// The cron checks this before inserting a duplicate alert for the same
  /// problem on the same target — only a fresh trigger (status change, new
  /// dispute) creates a new row.
  triggerKey       String?        @db.VarChar(140)
  /// Free-text reason that triggered this firing — surfaced in the detail
  /// panel and useful when the same key fires for different reasons.
  triggerReason    String?        @db.VarChar(255)
  // Legacy boolean kept for backwards compat — derived from `status`.
  isResolved       Boolean        @default(false)
  // Workflow timestamps + actors
  ackedById        String?
  ackedAt          DateTime?
  resolvedById     String?
  resolvedBy       User?          @relation("AlertResolver", fields: [resolvedById], references: [id])
  resolvedAt       DateTime?
  resolutionNotes  String?        @db.VarChar(500)
  dismissedById    String?
  dismissedAt      DateTime?
  escalatedById    String?
  escalatedAt      DateTime?
  /// Computed at resolve time so we don't recompute in every list query.
  resolutionDurationSec Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt

  @@index([status, severity, createdAt(sort: Desc)])
  @@index([category])
  @@index([type])
  @@index([triggerKey])
}

// ============================================
// Promotional banners / offers
// ============================================

model Offer {
  id        String   @id @default(cuid())
  title     String
  titleAr   String
  imageUrl  String
  linkType  LinkType @default(NONE)
  linkValue String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ============================================
// Settings (admin-tunable key/value)
// ============================================

model Setting {
  key         String   @id
  value       Json
  description String?  @db.VarChar(500)
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ============================================
// Auth tokens
// ============================================

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  userAgent String?  @db.VarChar(500)
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================
// Coupons (admin-tunable, customer-applied)
// ============================================

enum CouponType {
  PERCENTAGE
  FLAT
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique @db.VarChar(40)
  type            CouponType
  /// PERCENTAGE: 0..100. FLAT: amount in EGP.
  value           Decimal      @db.Decimal(10, 2)
  /// Order must be at least this much for the coupon to apply.
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  /// For PERCENTAGE, caps the discount at this absolute amount.
  maxDiscount     Decimal?     @db.Decimal(10, 2)
  /// Optional time window. Null = no bound.
  validFrom       DateTime?
  validTo         DateTime?
  /// Hard cap on total redemptions across all users. Null = unlimited.
  usageLimit      Int?
  /// Per-user cap. Defaults to 1 (single-use per customer) when null.
  usagePerUser    Int?         @default(1)
  isActive        Boolean      @default(true)
  description     String?      @db.VarChar(500)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  redemptions     CouponRedemption[]

  @@index([isActive, code])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discount  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}

// ============================================
// Wallet (customer credit balance)
// ============================================

enum WalletTxType {
  EARN
  SPEND
  REFUND
  MANUAL_CREDIT
  MANUAL_DEBIT
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  totalEarned Decimal  @default(0) @db.Decimal(10, 2)
  totalSpent  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions WalletTransaction[]
}

model WalletTransaction {
  id            String       @id @default(cuid())
  walletId      String
  wallet        Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          WalletTxType
  /// Positive amount; the type field determines the sign.
  amount        Decimal      @db.Decimal(10, 2)
  /// Wallet balance after this tx is applied.
  balanceAfter  Decimal      @db.Decimal(10, 2)
  orderId       String?      @db.VarChar(40)
  reason        String?      @db.VarChar(500)
  createdById   String?
  createdAt     DateTime     @default(now())

  @@index([walletId, createdAt(sort: Desc)])
  @@index([orderId])
}

// ============================================
// OTP codes — phone verification + auth flows
// ============================================
// One-time codes sent over WhatsApp / SMS. We never store the code in clear:
// we hash with SHA-256 and compare hash-to-hash on verify. Expiry is short
// (5 min) and attempts capped at 5 to defeat brute force. Old rows are
// hard-deleted by the daily auth cleanup cron, not by row-level TTL.
model OtpCode {
  id         String   @id @default(cuid())
  phone      String   @db.VarChar(20)
  codeHash   String   @db.VarChar(64)
  /// Purpose — distinguishes a registration OTP from a password-reset OTP.
  purpose    String   @default("VERIFY") @db.VarChar(20)
  attempts   Int      @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([phone, createdAt(sort: Desc)])
  @@index([expiresAt])
}

// ============================================
// AdminAuditLog — durable trail of admin writes
// ============================================
// Persists every state-changing /admin/* action so we can answer "who
// changed X, when, and to what value?" months later. Read endpoints
// (GET) are excluded — only POST/PATCH/PUT/DELETE land here, captured
// by the audit middleware in src/middleware/audit.ts.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  UserRole
  method     String   @db.VarChar(10)
  path       String   @db.VarChar(255)
  targetType String?  @db.VarChar(60)
  targetId   String?  @db.VarChar(80)
  /// Sanitized request body (no passwords / tokens). Useful for diff replay.
  payload    Json?
  ip         String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  status     Int?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([path, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// RecurringOrder — template that auto-creates an Order on a schedule
// ============================================
// Customer says "deliver me bottled water every Monday at 10am" — we save
// the recipe here and the scheduledOrders cron (runs hourly) inserts a
// fresh Order whenever `nextRunAt` <= now. After insert we bump nextRunAt
// by `frequency`.
//
// We deliberately do NOT carry order status fields on this template — only
// the inputs needed to construct a new Order. The generated Order starts at
// NEW just like any other.

enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model RecurringOrder {
  id              String              @id @default(cuid())
  customerId      String
  customer        User                @relation("CustomerRecurring", fields: [customerId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service             @relation(fields: [serviceId], references: [id])
  /// Optional label shown to the customer ("مياه أسبوعية", "أدوية الشهر").
  label           String?             @db.VarChar(120)
  category        ServiceCategory
  merchantId      String?

  // Order inputs — mirror Order's create-time fields, minus pricing/status.
  customData      Json?
  notes           String?             @db.Text
  imageUrls       Json?
  paymentMethod   PaymentMethod?
  deliveryAddress String?             @db.VarChar(500)
  deliveryLat     Decimal?            @db.Decimal(10, 7)
  deliveryLng     Decimal?            @db.Decimal(10, 7)

  // Cadence
  frequency       RecurringFrequency
  /// 0=Sun..6=Sat (for WEEKLY/BIWEEKLY). null for DAILY/MONTHLY.
  dayOfWeek       Int?
  /// 1..28 for MONTHLY (kept <=28 to dodge month-length edge cases). null otherwise.
  dayOfMonth      Int?
  /// Local hour 0..23 we want the order created. Combined with the
  /// customer's TZ offset client-side; server stores literal hour.
  hour            Int                 @default(10)

  isActive        Boolean             @default(true)
  lastGeneratedAt DateTime?
  nextRunAt       DateTime
  /// Stop auto-generating after this date (null = forever).
  endsAt          DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([customerId, isActive])
  @@index([nextRunAt, isActive])
}

// ============================================
// HomeConfig — admin-editable content for the mobile home screen
// ============================================
// Singleton table (id is always 'singleton') so admins can rewrite the
// hero copy, swap which merchants/offers/services get featured, and
// tweak the trust strip without redeploying the app.
//
// The mobile fetches it on cold start; the dashboard PATCHes it.

model HomeConfig {
  id                String   @id @default("singleton")
  heroGreeting      String?  @db.VarChar(120)
  heroSubtitle      String?  @db.VarChar(160)
  /// JSON array of strings — hex colors used to render the gradient
  /// (length must be 2-4). Falls back to brand red→orange when null.
  heroGradient      Json?
  trustStripTitle   String?  @db.VarChar(120)
  trustStripSubtitle String?  @db.VarChar(160)
  /// Preferred way to set the promo banner — pick an existing Coupon and
  /// the mobile renders its title/code/description live. Falls back to the
  /// free-text fields below when null (legacy or quick one-off banners).
  promoBannerCouponId String? @db.VarChar(30)
  promoBannerTitle  String?  @db.VarChar(140)
  promoBannerCode   String?  @db.VarChar(40)
  /// JSON array of service keys ('delivery-supermarket', 'delivery-pharmacy', ...)
  /// that should appear on the home tiles, in display order. When null we
  /// render whatever the Services table returns.
  visibleServiceKeys Json?
  /// JSON array of merchant IDs to pin in the "featured" rail. Null = pick
  /// top-rated 4 from the merchants table.
  featuredMerchantIds Json?
  /// JSON array of offer IDs to display. Null = newest offer.
  featuredOfferIds  Json?
  /// When false, hide promo banner entirely.
  showPromoBanner   Boolean  @default(true)
  /// When false, hide the trust strip at the bottom.
  showTrustStrip    Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  updatedById       String?
}
