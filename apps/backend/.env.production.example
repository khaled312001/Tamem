# ============================================================
# Tamem Delivery — Production environment template
# ============================================================
# Copy this file to `.env` on the VPS and fill in the real values.
# NEVER commit the real .env. Store the real values in 1Password.
#
# Rotation strategy:
#   - JWT secrets: 6 months OR after any team-member departure
#   - Paymob keys: only when Paymob's dashboard rotates them
#   - WhatsApp Cloud token: 60 days (Meta auto-expires)
#   - Google client secret: only on suspected leak
# ============================================================

NODE_ENV=production
PORT=4000
API_BASE_URL=https://api.deliverytamem.com

# --------- Database ---------
# Hostinger Cloud MySQL — shared by Khaled + Ahmed in dev and by the
# production backend. Add your dev box IP at
#   hPanel → Advanced → Remote MySQL → Add IP
# Password URL-encoded: `?` → %3F, `!` → %21
DATABASE_URL="mysql://u405809647_tamem:tamemg%3F026d%21L@srv2123.hstgr.io:3306/u405809647_tamem"
# If you prefer the local-VPS DB instead, comment out the above and use:
# DATABASE_URL="mysql://tamem:STRONG_PASSWORD_HERE@127.0.0.1:3306/tamem"
# SHADOW_DATABASE_URL="mysql://tamem:STRONG_PASSWORD_HERE@127.0.0.1:3306/tamem_shadow"

# --------- Auth ---------
# Generate fresh values with: openssl rand -hex 48
JWT_ACCESS_SECRET=REPLACE_WITH_HEX_48
JWT_REFRESH_SECRET=REPLACE_WITH_HEX_48
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --------- CORS allowlist (no wildcards, no localhost) ---------
CORS_ORIGINS=https://admin.deliverytamem.com,https://deliverytamem.com

# --------- Google OAuth (mobile sign-in) ---------
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — enables Distance Matrix instead of Haversine fallback.
GOOGLE_MAPS_API_KEY=

# --------- WhatsApp Cloud API (fallback when WppConnect QR disconnects) ---------
# Get from https://developers.facebook.com/apps/<app-id>/whatsapp-business
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_NUMBER=+201010254819

# --------- Firebase Cloud Messaging (Android push) ---------
# Path to the service-account JSON downloaded from
# https://console.firebase.google.com/project/<id>/settings/serviceaccounts/adminsdk
# Place the file at /home/tamem/.secrets/firebase-sa.json with chmod 600.
FCM_SERVICE_ACCOUNT_JSON_PATH=/home/tamem/.secrets/firebase-sa.json

# --------- SMS provider (OTP fallback when no WhatsApp) ---------
# Generic shape that fits Twilio, Vonage, MessageBird, Smsala, etc.
# When unset, OTP delivery is WhatsApp-only.
#
# Twilio example:
#   SMS_PROVIDER_URL=https://api.twilio.com/2010-04-01/Accounts/<sid>/Messages.json
#   SMS_PROVIDER_TOKEN=<auth-token>
#   SMS_SENDER=+1xxxxxxxxxx
#   SMS_PROVIDER_TO_KEY=To
#   SMS_PROVIDER_BODY_KEY=Body
#
# Smsala (Egypt) example:
#   SMS_PROVIDER_URL=https://api.smsala.com/api/SendSMS
#   SMS_PROVIDER_TOKEN=<api-key>
#   SMS_SENDER=Tamem
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=
SMS_SENDER=Tamem
SMS_PROVIDER_TO_KEY=
SMS_PROVIDER_BODY_KEY=

# --------- EasyKash (single payment gateway) ---------
# Dashboard: https://back.easykash.net  (Egypt)
# Docs:      https://easykash.gitbook.io/easykash-apis-documentation
#
# Setup flow (one-time):
#   1. Sign in to EasyKash and open Integration Settings → copy the API Key here.
#   2. Set the Callback URL in EasyKash to:
#        https://api.deliverytamem.com/api/v1/payments/webhook/easykash
#   3. Tick the payment methods you want enabled (Visa, MasterCard, Meeza,
#      Vodafone Cash, InstaPay), Save.
#   4. EasyKash reveals the HMAC Secret → paste it here.
#
# Tip: leave these blank if the admin enters them via /payment-gateway in
# the dashboard — the Setting table value wins over env.
EASYKASH_API_KEY=
EASYKASH_HMAC_SECRET=
# Comma-separated enum IDs of the payment methods enabled in the EasyKash
# dashboard. The customer picks one on EasyKash's hosted page; we don't show
# a per-method picker in the app. Default covers all 5 supported methods.
EASYKASH_PAYMENT_OPTIONS=2,3,4,5,6
# Where EasyKash redirects the customer back to after they finish paying.
# Default: backend's own /payments/return endpoint (renders a close-tab page).
EASYKASH_REDIRECT_URL=https://api.deliverytamem.com/api/v1/payments/return

# --------- Uploads ---------
# Absolute path — used by multer + served by nginx alias /uploads/.
UPLOAD_DIR=/var/www/tamem/apps/backend/uploads
UPLOAD_MAX_BYTES=10485760

# --------- Operational limits ---------
DRIVER_CASH_LIMIT=1000
