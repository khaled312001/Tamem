---
import Icon from './Icon.astro';
---

<section
  id="download"
  class="relative py-24 px-6 overflow-hidden text-white"
  style="background: linear-gradient(135deg, #241310 0%, #3a1a14 40%, #E0301E 100%);"
>
  <!-- Gold accent line -->
  <div class="absolute inset-x-0 top-0 h-[3px]" style="background: linear-gradient(90deg, transparent, #F2A93B, transparent);"></div>

  <div class="absolute -top-32 right-1/4 w-96 h-96 rounded-full blob-anim pointer-events-none" style="background: rgba(242,169,59,0.18); filter: blur(80px);"></div>
  <div class="absolute bottom-0 -left-32 w-96 h-96 rounded-full blob-anim pointer-events-none" style="background: rgba(236,122,44,0.18); filter: blur(80px); animation-delay: -8s;"></div>

  <div class="relative max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
    <div>
      <span
        class="reveal inline-flex items-center gap-1.5 backdrop-blur text-xs font-black px-3 py-1.5 rounded-full mb-5 border"
        style="background: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.20);"
      >
        <Icon name="sparkles" size={14} class="text-brand-gold" />
        خصم 20% على أول طلب
      </span>
      <h2 class="reveal reveal-delay-1 text-3xl md:text-5xl font-black leading-tight mb-5">
        التطبيق على Android.<br />
        <span class="shine-text">حمّله دلوقتي.</span>
      </h2>
      <p class="reveal reveal-delay-2 text-white/85 text-lg mb-8 leading-relaxed">
        تطبيق خفيف، يفتح بسرعة، عربي 100%. نسخة iOS هتتبعت لـ App Store قريباً.
      </p>

      <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
        <a
          href="#"
          class="group inline-flex items-center gap-3 bg-white text-brand-dark font-bold px-6 py-3.5 rounded-2xl hover:scale-105 hover:shadow-[0_20px_40px_-10px_rgba(242,169,59,0.6)] transition-all"
        >
          <Icon name="play-store" size={36} class="text-brand-red" />
          <span class="text-right">
            <span class="block text-[10px] opacity-60 leading-none">حمّل من</span>
            <span class="block text-base leading-tight mt-0.5">Google Play</span>
          </span>
        </a>
        <a
          href="#"
          class="inline-flex items-center gap-3 backdrop-blur text-white font-bold px-6 py-3.5 rounded-2xl border cursor-not-allowed opacity-70"
          style="background: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.20);"
        >
          <Icon name="app-store" size={32} />
          <span class="text-right">
            <span class="block text-[10px] opacity-60 leading-none">قريباً على</span>
            <span class="block text-base leading-tight mt-0.5">App Store</span>
          </span>
        </a>
      </div>
    </div>

    <!-- QR + rider badge -->
    <div class="relative flex items-center justify-center">
      <div class="relative bg-white text-brand-dark rounded-3xl p-6 shadow-2xl max-w-xs float-anim">
        <div class="aspect-square bg-white border-8 rounded-xl mb-4 grid grid-cols-12 grid-rows-12 gap-px p-2 overflow-hidden" style="border-color:#241310;">
          {Array.from({ length: 144 }, (_, i) => (
            <div class={[1,2,5,7,8,11,13,14,17,19].includes(i % 23) ? '' : 'opacity-0'} style="background:#241310;"></div>
          ))}
        </div>
        <p class="text-center font-black text-sm">امسح وحمّل التطبيق</p>
        <p class="text-center text-xs text-brand-gray mt-1" dir="ltr">+201070750167</p>
      </div>

      <!-- Floating gold rider badge -->
      <div class="absolute -top-4 -right-4 rounded-full w-20 h-20 grid place-items-center text-brand-dark shadow-2xl float-anim" style="background: linear-gradient(135deg,#F2A93B,#FFC76A); animation-delay: -3s;">
        <Icon name="bike" size={32} />
      </div>
    </div>
  </div>
</section>
