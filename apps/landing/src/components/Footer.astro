---
import Icon from './Icon.astro';
import { TAMEM_CONTACTS, TAMEM_PRIMARY_PHONE } from '../config/contact';

const WHATSAPP = import.meta.env.PUBLIC_TAMEM_WHATSAPP || TAMEM_PRIMARY_PHONE;
const year = new Date().getFullYear();
---

<footer class="relative pt-16 pb-8 px-6 overflow-hidden text-white" style="background:#0A0503;">
  <div class="absolute top-0 inset-x-0 h-1" style="background: linear-gradient(90deg, #E0301E, #EC7A2C, #F2A93B);"></div>

  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-12 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-4">
        <div class="bg-white rounded-2xl p-3 inline-block mb-4 shadow-xl">
          <img src="/logo.png" alt="تميم للتوصيل" class="h-16 w-auto" />
        </div>
        <p class="text-white/65 leading-relaxed text-sm">
          منصة توصيل وشحن متكاملة تخدم قفط وقنا والصعيد. نتوسع لتغطية الأقصر وأسوان والبحر الأحمر قريباً.
        </p>

        <div class="flex gap-3 mt-5">
          <a href={`https://wa.me/${WHATSAPP.replace(/[^\d]/g, '')}`} target="_blank" rel="noreferrer" aria-label="WhatsApp"
             class="w-10 h-10 rounded-full bg-white/10 hover:bg-green-500 grid place-items-center transition">
            <Icon name="whatsapp" size={18} />
          </a>
          <a href="https://www.facebook.com/profile.php?id=100064713581319" target="_blank" rel="noreferrer" aria-label="Facebook"
             class="w-10 h-10 rounded-full bg-white/10 hover:bg-[#1877F2] grid place-items-center transition">
            <Icon name="facebook" size={18} />
          </a>
          <a href="https://www.tiktok.com/@deliverytamem0" target="_blank" rel="noreferrer" aria-label="TikTok"
             class="w-10 h-10 rounded-full bg-white/10 hover:bg-black grid place-items-center transition">
            <Icon name="tiktok" size={18} />
          </a>
          <a href="/links" aria-label="كل الروابط"
             class="w-10 h-10 rounded-full bg-white/10 grid place-items-center transition"
             onmouseover="this.style.background='linear-gradient(135deg,#E0301E,#F2A93B)'"
             onmouseout="this.style.background='rgba(255,255,255,0.1)'"
          >
            <Icon name="qr" size={18} />
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="md:col-span-2">
        <h4 class="font-black mb-4" style="color:#F2A93B;">المنصة</h4>
        <ul class="space-y-2 text-sm text-white/65">
          <li><a href="#services" class="hover:text-white transition">الخدمات</a></li>
          <li><a href="#how" class="hover:text-white transition">كيف يعمل</a></li>
          <li><a href="#features" class="hover:text-white transition">المميزات</a></li>
          <li><a href="#download" class="hover:text-white transition">حمّل التطبيق</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="font-black mb-4" style="color:#F2A93B;">الشركاء</h4>
        <ul class="space-y-2 text-sm text-white/65">
          <li><a href="#" class="hover:text-white transition">للتجار</a></li>
          <li><a href="#" class="hover:text-white transition">للسائقين</a></li>
          <li><a href="/privacy" class="hover:text-white transition">سياسة الخصوصية</a></li>
          <li><a href="/terms" class="hover:text-white transition">شروط الاستخدام</a></li>
          <li><a href="/delete-account" class="hover:text-white transition">حذف الحساب</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h4 class="font-black mb-4" style="color:#F2A93B;">تواصل</h4>
        <ul class="space-y-2.5 text-sm text-white/80">
          <li class="flex items-center gap-2">
            <Icon name="map-pin" size={14} class="text-brand-gold shrink-0" />
            المقر الرئيسي — مركز قفط، محافظة قنا
          </li>
          {TAMEM_CONTACTS.map((c) => (
            <li class="flex flex-col gap-0.5 pt-1">
              <span class="text-xs text-white/55">{c.labelAr}</span>
              <a href={`tel:${c.phone}`} dir="ltr" class="hover:text-white font-mono">{c.phone}</a>
            </li>
          ))}
          <li class="flex items-center gap-2 pt-1 border-t border-white/10 mt-2">
            <Icon name="mail" size={14} class="text-brand-gold shrink-0" />
            <a href="mailto:info@deliverytamem.com" class="hover:text-white">info@deliverytamem.com</a>
          </li>
          <li class="flex items-center gap-2">
            <Icon name="clock" size={14} class="text-brand-gold shrink-0" />
            يومياً 10 صباحاً - 1 بعد منتصف الليل
          </li>
        </ul>
      </div>
    </div>

    <!-- Barmagly credit -->
    <div class="border-t pt-8 pb-2 grid md:grid-cols-2 gap-6 items-center" style="border-color: rgba(255,255,255,0.08);">
      <div class="text-sm text-white/55">
        © {year} <strong class="text-white">تميم للتوصيل</strong>. كل الحقوق محفوظة.
      </div>
      <div class="md:text-left">
        <a
          href="http://barmagly.tech/"
          target="_blank" rel="noreferrer"
          class="group inline-flex items-center gap-3 rounded-2xl px-4 py-2.5 transition-all border"
          style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08);"
          onmouseover="this.style.borderColor='rgba(242,169,59,0.4)'; this.style.background='rgba(242,169,59,0.05)'"
          onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.background='rgba(255,255,255,0.04)'"
        >
          <div class="w-10 h-10 rounded-xl overflow-hidden bg-white p-0.5 shadow-md group-hover:scale-110 transition">
            <img src="/barmagly-logo.jpg" alt="شركة برمجلي" class="w-full h-full object-contain" />
          </div>
          <div class="text-right">
            <div class="text-[10px] text-white/60 leading-tight">تطوير وتنفيذ</div>
            <div class="font-black text-sm text-white leading-tight">شركة برمجلي</div>
          </div>
          <div class="flex items-center gap-1.5 ms-2">
            <span
              onclick="event.preventDefault(); window.open('https://www.facebook.com/BarmaglyOfficial/','_blank')"
              role="button" tabindex="0" aria-label="Barmagly Facebook"
              class="w-7 h-7 rounded-md grid place-items-center transition cursor-pointer"
              style="background: rgba(255,255,255,0.10);"
              onmouseover="this.style.background='#1877F2'"
              onmouseout="this.style.background='rgba(255,255,255,0.10)'"
            >
              <Icon name="facebook" size={14} />
            </span>
            <span
              onclick="event.preventDefault(); window.open('https://wa.me/201070750167','_blank')"
              role="button" tabindex="0" aria-label="Barmagly WhatsApp"
              class="w-7 h-7 rounded-md grid place-items-center transition cursor-pointer"
              style="background: rgba(255,255,255,0.10);"
              onmouseover="this.style.background='#25D366'"
              onmouseout="this.style.background='rgba(255,255,255,0.10)'"
            >
              <Icon name="whatsapp" size={14} />
            </span>
          </div>
        </a>
      </div>
    </div>
  </div>
</footer>
