---
import Icon, { type IconName } from './Icon.astro';

const services: {
  icon: IconName;
  title: string;
  desc: string;
  bullets: string[];
  iconBg: string;
}[] = [
  {
    icon: 'shopping-bag',
    title: 'دليفري داخل المدينة',
    desc: 'سوبر ماركت، صيدلية، مطاعم، حجز دكتور، توصيل مستندات.',
    bullets: ['متوسط زمن 30-45 دقيقة', 'مندوب يتصل قبل التوصيل', 'دفع كاش أو إلكتروني'],
    iconBg: 'linear-gradient(135deg,#E0301E,#EC7A2C)',
  },
  {
    icon: 'package',
    title: 'شحن بين المناطق',
    desc: 'شحن طرود وبضائع بين قنا والأقصر وأسوان والبحر الأحمر — بوصلة سعر فورية.',
    bullets: ['تسعير حسب المسافة + الوزن', 'تأمين على الطرود الهشة', 'خيار شحن سريع (6 ساعات)'],
    iconBg: 'linear-gradient(135deg,#EC7A2C,#F2A93B)',
  },
  {
    icon: 'store',
    title: 'طلبات تجار B2B',
    desc: 'مخصص للشركات والمحلات: منتجات متعددة من مخازن مختلفة لعدة فروع.',
    bullets: ['multi-pickup + multi-delivery', 'عرض سعر مخصص لكل طلب', 'حساب تجاري ومتابعة شهرية'],
    iconBg: 'linear-gradient(135deg,#F2A93B,#FFC76A)',
  },
];
---

<section id="services" class="relative py-24 px-6" style="background:#0F0805;">
  <!-- Top gold accent -->
  <div class="absolute inset-x-0 top-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(242,169,59,0.3), transparent);"></div>

  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-14 reveal">
      <span
        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-black mb-3 border"
        style="background: rgba(224,48,30,0.15); color: #F2A93B; border-color: rgba(242,169,59,0.2);"
      >
        <Icon name="sparkles" size={14} />
        خدماتنا
      </span>
      <h2 class="text-3xl md:text-5xl font-black mb-4 text-white">
        ثلاث خدمات. تطبيق واحد.
      </h2>
      <p class="text-white/60 max-w-xl mx-auto">
        كل ما تحتاجه للتوصيل والشحن في مكان واحد — مصمم خصيصاً لمدن الصعيد.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} tilt-card group relative rounded-3xl p-7 border transition-all`}
          style="background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01)); border-color: rgba(255,255,255,0.08);"
        >
          <!-- Icon disc -->
          <div class="relative w-16 h-16 mb-5">
            <div class="absolute inset-0 rounded-2xl blur-lg" style={`background: ${s.iconBg}; opacity: 0.45; transform: scale(1.15);`}></div>
            <div
              class="relative w-16 h-16 rounded-2xl grid place-items-center text-white shadow-lg group-hover:scale-110 group-hover:rotate-3 transition-transform"
              style={`background: ${s.iconBg};`}
            >
              <Icon name={s.icon} size={28} />
            </div>
          </div>

          <h3 class="text-xl font-black mb-2 text-white">{s.title}</h3>
          <p class="text-sm text-white/65 mb-5 leading-relaxed">{s.desc}</p>

          <ul class="space-y-2 pt-4 border-t" style="border-color: rgba(255,255,255,0.08);">
            {s.bullets.map((b) => (
              <li class="flex items-start gap-2 text-sm text-white/85">
                <span class="w-5 h-5 rounded-full grid place-items-center shrink-0 mt-0.5" style="background: rgba(242,169,59,0.18); color: #F2A93B;">
                  <Icon name="check" size={12} />
                </span>
                {b}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
