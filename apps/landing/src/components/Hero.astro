---
import Icon from './Icon.astro';

const WHATSAPP = import.meta.env.PUBLIC_TAMEM_WHATSAPP || '+201010254819';
const waLink = `https://wa.me/${WHATSAPP.replace(/[^\d]/g, '')}?text=${encodeURIComponent('أهلاً، عاوز أعرف أكتر عن تميم للتوصيل')}`;
---

<!--
  Hero = Mobile SplashScreen, web-ified.
  Background gradient + gold accent line + decorative circles + rider portrait
  with gold ring + logo badge are all 1:1 with apps/mobile/src/screens/SplashScreen.tsx.
-->
<section
  id="top"
  class="relative pt-28 pb-32 md:pt-32 md:pb-40 overflow-hidden text-white"
  style="background: linear-gradient(135deg, #E0301E 0%, #C4280F 28%, #9A1A0A 60%, #241310 100%);"
>
  <!-- Gold accent line (same as splash) -->
  <div
    class="absolute top-0 inset-x-0 h-[3px]"
    style="background: linear-gradient(90deg, transparent, #F2A93B, transparent);"
  ></div>

  <!-- Decorative circles from splash -->
  <div class="absolute -top-10 -right-10 w-[200px] h-[200px] rounded-full bg-white/[0.04]"></div>
  <div class="absolute top-8 right-5 w-[140px] h-[140px] rounded-full bg-white/[0.03]"></div>
  <div class="absolute bottom-24 -left-8 w-[160px] h-[160px] rounded-full" style="background: rgba(236,122,44,0.10);"></div>

  <!-- Animated gold blob -->
  <div class="absolute top-1/3 right-1/3 w-96 h-96 rounded-full blob-anim pointer-events-none" style="background: rgba(242,169,59,0.10); filter: blur(80px);"></div>

  <div class="relative max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-12 items-center">

    <!-- ============= Copy column ============= -->
    <div class="lg:col-span-7 text-center lg:text-right order-2 lg:order-1">
      <!-- Live badge -->
      <div class="reveal inline-flex items-center gap-2 backdrop-blur rounded-full px-4 py-1.5 mb-6 text-xs font-bold border" style="background: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.15);">
        <span class="relative inline-flex w-2 h-2 rounded-full" style="background: #F2A93B;">
          <span class="absolute inline-flex w-full h-full rounded-full opacity-75 animate-ping" style="background: #F2A93B;"></span>
        </span>
        خدمة متاحة الآن في قفط — توسّع قريب
      </div>

      <!-- TAMEM DELIVERY brand block (lifted from splash) -->
      <div class="reveal reveal-delay-1 mb-6 lg:hidden flex flex-col items-center">
        <div class="text-white font-black text-2xl" style="letter-spacing: 6px;">TAMEM</div>
        <div class="flex items-center gap-2.5 mt-1">
          <div class="w-6 h-px" style="background: rgba(242,169,59,0.7);"></div>
          <div class="font-extrabold text-[10px]" style="color: #F2A93B; letter-spacing: 8px;">DELIVERY</div>
          <div class="w-6 h-px" style="background: rgba(242,169,59,0.7);"></div>
        </div>
      </div>

      <h1 class="reveal reveal-delay-1 text-[2.6rem] sm:text-6xl lg:text-7xl font-black leading-[1.4] mb-6">
        <span class="block pb-1">توصيلك في</span>
        <span class="block">أمان <span class="shine-text">معانا</span></span>
      </h1>

      <p class="reveal reveal-delay-2 text-lg md:text-xl text-white/85 mb-8 max-w-xl lg:mx-0 mx-auto leading-relaxed">
        منصة توصيل وشحن متكاملة. اطلب من <strong class="text-white">السوبر ماركت أو الصيدلية أو المطعم</strong>،
        اشحن طرود بين المحافظات، أو شغّل تجارتك مع مندوبين ثقة — كله من تطبيق واحد، في 3 ضغطات.
      </p>

      <!-- Tagline pill (from splash) -->
      <div class="reveal reveal-delay-3 inline-flex items-center gap-2.5 mb-8 backdrop-blur rounded-full px-5 py-2 border" style="background: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.15);">
        <Icon name="bike" size={18} class="text-white" />
        <span class="font-bold text-sm">تميم… التوصيل لعبتنا</span>
      </div>

      <div class="reveal reveal-delay-3 flex flex-wrap gap-3 justify-center lg:justify-start mb-8">
        <a
          href="#download"
          class="group inline-flex items-center gap-3 bg-white text-brand-dark font-bold px-6 py-3.5 rounded-2xl hover:scale-105 hover:shadow-[0_20px_40px_-15px_rgba(242,169,59,0.6)] transition-all"
        >
          <Icon name="play-store" size={22} class="text-brand-red" />
          <span class="text-right">
            <span class="block text-[10px] opacity-60 leading-none">حمّل من</span>
            <span class="block text-base leading-tight mt-0.5">Google Play</span>
          </span>
        </a>
        <a
          href={waLink}
          target="_blank" rel="noreferrer"
          class="inline-flex items-center gap-2 backdrop-blur text-white font-bold px-6 py-3.5 rounded-2xl border hover:bg-white/15 transition"
          style="background: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.20);"
        >
          <Icon name="whatsapp" size={20} />
          تواصل واتساب
        </a>
      </div>

      <!-- Trust badges -->
      <div class="reveal reveal-delay-4 flex flex-wrap items-center justify-center lg:justify-start gap-6 text-sm">
        <div class="flex items-center gap-2">
          <div class="flex -space-x-1.5">
            <div class="w-7 h-7 rounded-full border-2 border-brand-dark" style="background: linear-gradient(135deg,#E0301E,#EC7A2C);"></div>
            <div class="w-7 h-7 rounded-full border-2 border-brand-dark" style="background: linear-gradient(135deg,#EC7A2C,#F2A93B);"></div>
            <div class="w-7 h-7 rounded-full border-2 border-brand-dark" style="background: linear-gradient(135deg,#F2A93B,#FFE7B5);"></div>
            <div class="w-7 h-7 rounded-full border-2 border-brand-dark" style="background: linear-gradient(135deg,#FFE7B5,#fff);"></div>
          </div>
          <span class="text-white/85"><strong class="text-white">+100</strong> طلب يومياً</span>
        </div>
        <div class="flex items-center gap-1.5">
          {[1,2,3,4,5].map(() => (
            <Icon name="star" size={14} class="text-brand-gold" />
          ))}
          <span class="text-white/85 me-1"><strong class="text-white">4.9</strong> تقييم</span>
        </div>
      </div>
    </div>

    <!-- ============= Rider portrait (matches splash) ============= -->
    <div class="lg:col-span-5 flex items-center justify-center order-1 lg:order-2">
      <!-- Brand TAMEM DELIVERY (desktop only — on mobile it shows above the headline) -->
      <div class="relative">
        <!-- Outer glow -->
        <div
          class="absolute inset-0 rounded-full blur-2xl"
          style="background: rgba(242,169,59,0.18); transform: scale(1.18);"
        ></div>

        <!-- Gold ring -->
        <div
          class="absolute inset-0 rounded-full border-[1.5px] pointer-events-none"
          style="border-color: rgba(242,169,59,0.4); transform: scale(1.06);"
        ></div>

        <!-- Rider portrait -->
        <div
          class="relative w-[280px] md:w-[340px] aspect-square rounded-full overflow-hidden border-[3px] shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)] float-anim"
          style="border-color: rgba(255,255,255,0.18);"
        >
          <img src="/delivery-rider.png" alt="ساعي تميم" class="w-full h-full object-cover" />
        </div>

        <!-- Logo badge (rotated tile in corner — splash style) -->
        <div
          class="absolute bottom-0 left-0 w-20 h-20 bg-white rounded-2xl p-1.5 shadow-[0_10px_20px_rgba(0,0,0,0.35)] z-10"
          style="transform: rotate(-6deg);"
        >
          <img src="/logo.png" alt="تميم logo" class="w-full h-full object-contain" />
        </div>

        <!-- Floating notification card -->
        <div
          class="absolute -top-4 -right-4 bg-white text-brand-dark rounded-2xl shadow-2xl px-3 py-2 float-anim z-10 hidden sm:flex items-center gap-2"
          style="animation-delay: -2s;"
        >
          <div class="w-8 h-8 rounded-full grid place-items-center text-white" style="background: #1A9F6E;">
            <Icon name="check" size={16} />
          </div>
          <div class="text-right">
            <div class="font-black text-xs leading-tight">تم تسليم طلبك</div>
            <div class="text-[10px] text-brand-gray leading-tight">قبل 5 دقايق</div>
          </div>
        </div>

        <!-- Floating quick-order card -->
        <div
          class="absolute -bottom-3 -left-12 bg-white text-brand-dark rounded-2xl shadow-2xl px-3 py-2 float-anim z-10 hidden sm:flex items-center gap-2"
          style="animation-delay: -4s;"
        >
          <div class="w-8 h-8 rounded-full grid place-items-center text-white" style="background: linear-gradient(135deg,#E0301E,#EC7A2C);">
            <Icon name="zap" size={14} />
          </div>
          <div class="text-right">
            <div class="font-black text-xs leading-tight">طلب سريع</div>
            <div class="text-[10px] text-brand-gray leading-tight">3 ضغطات بس</div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Wave divider into dark surface -->
  <svg class="absolute -bottom-px left-0 right-0 w-full" viewBox="0 0 1440 80" preserveAspectRatio="none" style="color: #0F0805;">
    <path fill="currentColor" d="M0,40 C320,80 720,0 1440,40 L1440,80 L0,80 Z" />
  </svg>
</section>
