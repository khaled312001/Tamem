---
import Icon from './Icon.astro';

/**
 * Brand social-channels strip. Three premium gradient cards (Facebook /
 * TikTok / WhatsApp) under the existing Contact section, plus an inline
 * mini-QR card pointing at /links so visitors on desktop can hand the
 * page to anyone with a phone.
 */
const CHANNELS = [
  {
    label: 'فيسبوك',
    sub: 'Tamem Delivery',
    href: 'https://www.facebook.com/profile.php?id=100064713581319',
    icon: 'facebook' as const,
    bg: 'linear-gradient(135deg,#1877F2,#0a4fb3)',
    iconBg: '#1877F2',
    ringColor: 'rgba(24,119,242,0.5)',
  },
  {
    label: 'تيك توك',
    sub: '@deliverytamem0',
    href: 'https://www.tiktok.com/@deliverytamem0?_r=1&_t=ZS-977CxobNlY2',
    icon: 'tiktok' as const,
    bg: 'linear-gradient(135deg,#FE2C55,#25F4EE)',
    iconBg: '#000000',
    ringColor: 'rgba(254,44,85,0.5)',
  },
  {
    label: 'واتساب',
    sub: '01070750167',
    href: 'https://wa.me/201070750167',
    icon: 'whatsapp' as const,
    bg: 'linear-gradient(135deg,#25D366,#128C7E)',
    iconBg: '#25D366',
    ringColor: 'rgba(37,211,102,0.5)',
  },
];
---

<section id="social" class="py-20 px-6" style="background:#0F0805;">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12 reveal">
      <span
        class="inline-block px-4 py-1.5 rounded-full text-xs font-bold mb-4"
        style="background:rgba(242,169,59,0.15); color:#F2A93B; border:1px solid rgba(242,169,59,0.3);"
      >
        تابعنا على كل المنصات
      </span>
      <h2 class="text-3xl md:text-5xl font-black mb-3 text-white">FOLLOW US EVERYWHERE</h2>
      <p class="text-white/65 max-w-xl mx-auto">
        آخر العروض، الأكلات الجديدة، فيديوهات السائقين وتحديثات تميم — كل ده في انتظارك على قنواتنا.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {CHANNELS.map((c, i) => (
        <a
          href={c.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`reveal reveal-delay-${Math.min(i + 1, 4)} group relative overflow-hidden rounded-3xl p-6 border transition-all hover:-translate-y-2`}
          style={`background:${c.bg}; border-color: rgba(255,255,255,0.12); box-shadow: 0 20px 40px -20px ${c.ringColor};`}
        >
          <div
            aria-hidden="true"
            class="absolute -top-12 -right-12 w-44 h-44 rounded-full opacity-40 group-hover:opacity-70 transition-opacity"
            style="background: radial-gradient(circle, rgba(255,255,255,0.5), transparent 65%);"
          >
          </div>

          <div class="relative flex items-start gap-4">
            <div
              class="w-16 h-16 rounded-2xl grid place-items-center shrink-0 shadow-xl ring-2 ring-white/20 group-hover:scale-110 transition-transform"
              style={`background:${c.iconBg};`}
            >
              <Icon name={c.icon} size={32} class="text-white" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-white font-black text-xl leading-tight">{c.label}</div>
              <div class="text-white/85 text-sm mt-1 truncate" dir="ltr">{c.sub}</div>
            </div>
            <div
              class="text-white/75 group-hover:text-white group-hover:translate-x-[-4px] transition-all"
              aria-hidden="true"
            >
              <Icon name="chevron-left" size={22} />
            </div>
          </div>

          <div
            class="relative mt-5 inline-flex items-center gap-2 text-xs font-bold text-white/95 px-3 py-1.5 rounded-full"
            style="background:rgba(255,255,255,0.18); backdrop-filter:blur(8px);"
          >
            <Icon name="arrow-up-right" size={12} />
            <span>تابع الآن</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Unified-link mini banner: leads to /links page (linktree-style) -->
    <a
      href="/links"
      class="reveal reveal-delay-4 mt-8 group flex items-center gap-5 rounded-3xl p-6 border transition-all hover:-translate-y-1"
      style="background: linear-gradient(135deg, rgba(224,48,30,0.12), rgba(242,169,59,0.08)); border-color: rgba(242,169,59,0.30); box-shadow: 0 20px 40px -20px rgba(242,169,59,0.4);"
    >
      <img
        src="/qr-links.png"
        alt="QR code لصفحة كل روابط تميم"
        width="96"
        height="96"
        loading="lazy"
        class="w-24 h-24 rounded-2xl bg-white p-1.5 shrink-0 shadow-lg"
      />
      <div class="flex-1 min-w-0">
        <div class="font-black text-white text-lg">صفحة كل الروابط</div>
        <div class="text-white/70 text-sm mt-0.5">
          امسح كود QR أو افتح <span class="font-mono text-brand-gold" style="color:#F2A93B;">deliverytamem.com/links</span> لكل قنوات التواصل في صفحة واحدة
        </div>
      </div>
      <div
        class="hidden sm:inline-flex items-center gap-2 text-white font-bold text-sm px-4 py-2 rounded-xl shadow-md group-hover:scale-105 transition-transform"
        style="background: linear-gradient(135deg,#E0301E,#EC7A2C);"
      >
        <span>اعرض الصفحة</span>
        <Icon name="chevron-left" size={16} />
      </div>
    </a>
  </div>
</section>
