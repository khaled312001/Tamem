---
const steps = [
  { num: '01', title: 'اختر الخدمة', desc: 'دليفري أو شحن أو طلب تاجر — أو استخدم الزر السريع.', icon: '🎯' },
  { num: '02', title: 'أرسل الطلب', desc: 'تفاصيل + صور + موقع. بنحب الـ "اكتبه بسرعة" بدون فورمات معقدة.', icon: '✍️' },
  { num: '03', title: 'استلم تأكيد', desc: 'تأكيد فوري على التطبيق + واتساب + إشعار بحالة الطلب.', icon: '📱' },
  { num: '04', title: 'تابع وتسلّم', desc: 'تتبع لحظي للمندوب على الخريطة + استلام آمن.', icon: '✅' },
];
---

<section id="how" class="relative py-24 px-6 bg-gradient-to-b from-white to-brand-red/[0.03]">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 reveal">
      <span class="inline-block px-3 py-1 bg-brand-orange/10 text-brand-orange text-xs font-black rounded-full mb-3">
        كيف يعمل
      </span>
      <h2 class="text-3xl md:text-5xl font-black mb-4">من فكرة الطلب لـ "وصل" — 4 خطوات</h2>
      <p class="text-brand-gray max-w-xl mx-auto">صممنا الـ flow بحيث يكون أبسط من أي تطبيق توصيل تاني.</p>
    </div>

    <!-- Steps with connecting line -->
    <div class="relative grid md:grid-cols-4 gap-6">
      <!-- Horizontal connecting line (md+) -->
      <div class="hidden md:block absolute top-12 right-[12.5%] left-[12.5%] h-0.5 bg-gradient-to-l from-brand-red via-brand-orange to-brand-gold opacity-30"></div>

      {steps.map((step, i) => (
        <div class={`reveal reveal-delay-${i + 1} relative text-center`}>
          <!-- Step circle -->
          <div class="relative inline-flex w-24 h-24 mb-5">
            <div class="absolute inset-0 bg-gradient-to-br from-brand-red to-brand-orange rounded-full opacity-20 blur-xl"></div>
            <div class="relative w-24 h-24 bg-white border-2 border-brand-red/15 rounded-full grid place-items-center text-4xl shadow-lg hover:shadow-xl hover:scale-105 transition">
              {step.icon}
            </div>
            <div class="absolute -top-2 -right-2 w-10 h-10 bg-brand-dark text-brand-gold font-black text-sm rounded-full grid place-items-center border-4 border-white shadow-md">
              {step.num}
            </div>
          </div>
          <h3 class="text-lg font-black mb-2">{step.title}</h3>
          <p class="text-sm text-brand-gray leading-relaxed max-w-[18ch] mx-auto">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
