---
import Icon from './Icon.astro';

const WHATSAPP = import.meta.env.PUBLIC_TAMEM_WHATSAPP || '+201010254819';
const EMAIL = 'info@tamem-delivery.com';
---

<section id="contact" class="py-24 px-6" style="background:#0F0805;">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12 reveal">
      <h2 class="text-3xl md:text-5xl font-black mb-4 text-white">عاوز تتواصل معانا؟</h2>
      <p class="text-white/60 max-w-xl mx-auto">
        فريقنا متاح يومياً من 8 صباحاً لـ 12 منتصف الليل.
      </p>
    </div>

    <div class="grid sm:grid-cols-3 gap-4">
      <a
        href={`https://wa.me/${WHATSAPP.replace(/[^\d]/g, '')}`}
        target="_blank" rel="noreferrer"
        class="reveal reveal-delay-1 group flex flex-col items-center text-center rounded-2xl p-6 border hover:-translate-y-1 transition-all"
        style="background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01)); border-color: rgba(255,255,255,0.08);"
      >
        <div class="w-14 h-14 rounded-2xl bg-green-500 text-white grid place-items-center mb-3 group-hover:scale-110 transition shadow-lg shadow-green-500/30">
          <Icon name="whatsapp" size={24} />
        </div>
        <div class="font-black mb-1 text-white">واتساب</div>
        <div class="text-sm text-white/60" dir="ltr">{WHATSAPP}</div>
      </a>

      <a
        href={`tel:${WHATSAPP}`}
        class="reveal reveal-delay-2 group flex flex-col items-center text-center rounded-2xl p-6 border hover:-translate-y-1 transition-all"
        style="background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01)); border-color: rgba(255,255,255,0.08);"
      >
        <div class="w-14 h-14 rounded-2xl text-white grid place-items-center mb-3 group-hover:scale-110 transition shadow-lg" style="background:#E0301E; box-shadow: 0 8px 20px -8px rgba(224,48,30,0.6);">
          <Icon name="phone" size={24} />
        </div>
        <div class="font-black mb-1 text-white">اتصال مباشر</div>
        <div class="text-sm text-white/60" dir="ltr">{WHATSAPP}</div>
      </a>

      <a
        href={`mailto:${EMAIL}`}
        class="reveal reveal-delay-3 group flex flex-col items-center text-center rounded-2xl p-6 border hover:-translate-y-1 transition-all"
        style="background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01)); border-color: rgba(255,255,255,0.08);"
      >
        <div class="w-14 h-14 rounded-2xl text-white grid place-items-center mb-3 group-hover:scale-110 transition shadow-lg" style="background:#EC7A2C; box-shadow: 0 8px 20px -8px rgba(236,122,44,0.6);">
          <Icon name="mail" size={24} />
        </div>
        <div class="font-black mb-1 text-white">إيميل</div>
        <div class="text-sm text-white/60 break-all" dir="ltr">{EMAIL}</div>
      </a>
    </div>

    <div class="reveal mt-8 max-w-2xl mx-auto rounded-2xl p-5 flex items-center gap-4 border" style="background: rgba(242,169,59,0.08); border-color: rgba(242,169,59,0.20);">
      <div class="w-12 h-12 rounded-xl grid place-items-center" style="background: rgba(242,169,59,0.15); color:#F2A93B;">
        <Icon name="clock" size={22} />
      </div>
      <div>
        <div class="font-black text-white">ساعات العمل</div>
        <div class="text-sm text-white/65">كل يوم — من 8:00 صباحاً حتى 12:00 منتصف الليل</div>
      </div>
    </div>
  </div>
</section>
