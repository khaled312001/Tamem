---
/**
 * Linktree-style landing for the unified QR code (qr-output/tamem-all-links-qr.png).
 *
 * One short URL → every social channel + WhatsApp + the app's download
 * page in one tap. Mobile-first, vertical buttons, dark brand theme.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const CHANNELS = [
  {
    label: 'فيسبوك',
    sub: 'Tamem Delivery · Facebook',
    href: 'https://www.facebook.com/profile.php?id=100064713581319',
    bg: 'linear-gradient(135deg,#1877F2,#0a4fb3)',
    iconBg: '#1877F2',
    icon: 'facebook',
  },
  {
    label: 'تيك توك',
    sub: '@deliverytamem0',
    href: 'https://www.tiktok.com/@deliverytamem0?_r=1&_t=ZS-977CxobNlY2',
    bg: 'linear-gradient(135deg,#FE2C55,#25F4EE)',
    iconBg: '#000000',
    icon: 'tiktok',
  },
  {
    label: 'واتساب',
    sub: '01070750167',
    href: 'https://wa.me/201070750167',
    bg: 'linear-gradient(135deg,#25D366,#128C7E)',
    iconBg: '#25D366',
    icon: 'whatsapp',
  },
  {
    label: 'اتصل بنا',
    sub: '01070750167',
    href: 'tel:+201070750167',
    bg: 'linear-gradient(135deg,#E0301E,#F2A93B)',
    iconBg: '#E0301E',
    icon: 'phone',
  },
  {
    label: 'موقعنا',
    sub: 'tamem-delivery.com',
    href: '/',
    bg: 'linear-gradient(135deg,#241310,#58595B)',
    iconBg: '#F2A93B',
    icon: 'globe',
  },
];
---

<BaseLayout
  title="روابط تميم للتوصيل · كل القنوات"
  description="كل قنوات تواصل تميم للتوصيل في صفحة واحدة — فيسبوك، تيك توك، واتساب، والموقع."
>
  <main class="relative min-h-screen flex items-center justify-center px-5 py-12 overflow-hidden">
    <!-- Soft blob backdrop -->
    <div
      aria-hidden="true"
      class="absolute -top-32 -right-32 w-[420px] h-[420px] rounded-full blob-anim"
      style="background:radial-gradient(circle, rgba(224,48,30,0.18), transparent 70%);"
    >
    </div>
    <div
      aria-hidden="true"
      class="absolute -bottom-32 -left-32 w-[420px] h-[420px] rounded-full blob-anim"
      style="background:radial-gradient(circle, rgba(242,169,59,0.16), transparent 70%); animation-delay:-7s;"
    >
    </div>

    <article class="relative z-10 w-full max-w-md">
      <header class="text-center mb-9 reveal">
        <div class="inline-block relative">
          <div
            aria-hidden="true"
            class="absolute inset-0 rounded-full"
            style="background:radial-gradient(circle, rgba(242,169,59,0.4), transparent 60%); transform:scale(1.4); filter:blur(20px);"
          >
          </div>
          <img
            src="/logo.png"
            alt="تميم للتوصيل"
            width="120"
            height="120"
            class="relative rounded-3xl shadow-2xl border-2 border-white/10"
            style="background:#fff;"
          />
        </div>
        <h1 class="mt-5 text-3xl font-black text-white">تميم للتوصيل</h1>
        <p class="mt-2 text-white/70 text-sm">
          توصيلك في أمان معانا — قفط · قنا · الصعيد
        </p>
        <p class="mt-4 inline-block px-4 py-1.5 rounded-full text-xs font-bold"
          style="background:rgba(242,169,59,0.15); color:#F2A93B; border:1px solid rgba(242,169,59,0.3);">
          اختر طريقة التواصل
        </p>
      </header>

      <ul class="space-y-3.5">
        {CHANNELS.map((c, i) => (
          <li
            class={`reveal reveal-delay-${Math.min(i + 1, 4)}`}
          >
            <a
              href={c.href}
              target={c.href.startsWith('http') ? '_blank' : undefined}
              rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="group flex items-center gap-4 rounded-2xl px-4 py-3.5 border border-white/10 transition-all duration-300 hover:scale-[1.02] hover:border-white/30 hover:shadow-2xl"
              style={`background:${c.bg};`}
            >
              <span
                class="flex items-center justify-center w-12 h-12 rounded-xl shrink-0 shadow-lg"
                style={`background:${c.iconBg};`}
              >
                {c.icon === 'facebook' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
                    <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989C18.343 21.128 22 16.991 22 12z"/>
                  </svg>
                )}
                {c.icon === 'tiktok' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
                    <path d="M16.6 5.82s.51.5 0 0A4.278 4.278 0 0 1 15.54 3h-3.09v12.4a2.592 2.592 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6c0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64c0 3.33 2.76 5.7 5.69 5.7c3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3s-1.88.09-3.24-1.48"/>
                  </svg>
                )}
                {c.icon === 'whatsapp' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
                    <path d="M17.498 14.382c-.301-.15-1.767-.867-2.04-.966c-.273-.101-.473-.15-.673.15c-.197.295-.771.964-.944 1.162c-.175.195-.349.21-.646.075c-.3-.15-1.263-.465-2.403-1.485c-.888-.795-1.484-1.77-1.66-2.07c-.174-.3-.019-.465.13-.615c.136-.135.301-.345.451-.523c.146-.181.194-.301.297-.496c.1-.21.049-.375-.025-.524c-.075-.15-.672-1.62-.922-2.206c-.24-.584-.487-.51-.672-.51c-.172-.015-.371-.015-.571-.015c-.2 0-.523.074-.797.359c-.273.3-1.045 1.02-1.045 2.475c0 1.455 1.07 2.865 1.219 3.075c.149.195 2.105 3.195 5.1 4.485c.714.3 1.27.48 1.704.629c.715.227 1.365.195 1.88.121c.574-.091 1.767-.721 2.016-1.426c.255-.705.255-1.29.18-1.425c-.074-.135-.27-.21-.57-.345m-5.446 7.443h-.016a9.87 9.87 0 0 1-5.031-1.378l-.361-.214l-3.741.982l.998-3.648l-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884c2.64 0 5.122 1.03 6.988 2.898a9.83 9.83 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.81 11.81 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413"/>
                  </svg>
                )}
                {c.icon === 'phone' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
                    <path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57c-.35-.11-.74-.03-1.02.24l-2.2 2.2a15.045 15.045 0 0 1-6.59-6.58l2.2-2.21c.28-.27.36-.66.25-1.01A11.36 11.36 0 0 1 8.5 4c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1c0 9.39 7.61 17 17 17c.55 0 1-.45 1-1v-3.5c0-.55-.45-1-1-1"/>
                  </svg>
                )}
                {c.icon === 'globe' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
                    <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2m6.93 6h-2.95a15.65 15.65 0 0 0-1.38-3.56A8.03 8.03 0 0 1 18.92 8M12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96M4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56A7.987 7.987 0 0 1 5.08 16m2.95-8H5.08a7.987 7.987 0 0 1 4.33-3.56A15.65 15.65 0 0 0 8.03 8M12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96M14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2m.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 0 1-4.33 3.56M16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2z"/>
                  </svg>
                )}
              </span>
              <span class="flex-1">
                <span class="block font-black text-white text-lg leading-tight">{c.label}</span>
                <span class="block text-white/80 text-xs mt-0.5" dir="ltr">{c.sub}</span>
              </span>
              <svg
                aria-hidden="true"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-white/80 group-hover:translate-x-[-4px] transition-transform"
              >
                <path d="M15 18l-6-6 6-6" />
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <footer class="text-center mt-10 reveal">
        <p class="text-xs text-white/40">
          © {new Date().getFullYear()} Tamem Delivery · جميع الحقوق محفوظة
        </p>
      </footer>
    </article>
  </main>
</BaseLayout>
