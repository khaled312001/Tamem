---
import SeoSchema from '../components/SeoSchema.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}
const {
  title = 'تميم للتوصيل | دليفري وشحن في قفط وقنا وصعيد مصر',
  description = 'أول تطبيق توصيل دليفري وشحن متكامل في صعيد مصر. اطلب من مطاعم وصيدليات وسوبر ماركت قفط، أو اشحن طرودك لأي محافظة — المقر الرئيسي في مركز قفط، قنا.',
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const SITE = Astro.site ?? new URL('https://deliverytamem.com');
// build.format is 'directory', so pages are served WITH a trailing slash
// (dist/privacy/index.html → /privacy/). Normalise so canonical, og:url and the
// generated sitemap all spell the URL the same way — otherwise every non-root
// page canonicalises to a URL that 301s, and Google drops it as "page with redirect".
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonical = new URL(pathname, SITE).href;
// Open Graph requires an ABSOLUTE url. This was previously a bare '/og-image.png',
// so Facebook/WhatsApp silently dropped it and every shared link rendered with
// no thumbnail — on the two channels this brand actually runs on.
const ogImageUrl = new URL(ogImage, SITE).href;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#E0301E" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />}
    <meta name="author" content="تميم للتوصيل" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="تميم للتوصيل" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="تميم للتوصيل — دليفري وشحن في قفط وقنا وصعيد مصر" />
    <meta property="og:locale" content="ar_EG" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800;900&family=Tajawal:wght@400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <SeoSchema />
  </head>
  <body class="font-body antialiased overflow-x-hidden text-white" style="background:#0F0805;">
    <slot />

    {/* Site-config live hydration. Any element with a data-site attribute
        gets its textContent / href / src replaced by the matching value
        from GET /site-config. Failures are silent — the static fallback
        baked into each Astro component stays visible. */}
    <script is:inline>
      (async () => {
        try {
          // NOTE: api.deliverytamem.com does not exist (DNS returns nothing) —
          // the live API is served from the backendtamem subdomain. Pointing at
          // the wrong host made every dashboard edit silently never reach the site.
          const apiBase =
            window.localStorage.getItem('tamem-api-base') ||
            (window.location.hostname === 'localhost'
              ? 'http://localhost:4000/api/v1'
              : 'https://backendtamem.deliverytamem.com/api/v1');
          const res = await fetch(`${apiBase}/site-config`, { credentials: 'omit' });
          if (!res.ok) return;
          const { data } = await res.json();
          if (!data) return;

          const set = (selector, value) => {
            if (typeof value !== 'string' || !value) return;
            document.querySelectorAll(selector).forEach((el) => {
              if (el.tagName === 'A') el.setAttribute('href', value);
              else el.textContent = value;
            });
          };

          set('[data-site="heroTitle"]', data.heroTitle);
          set('[data-site="heroSubtitle"]', data.heroSubtitle);
          set('[data-site="heroCtaText"]', data.heroCtaText);
          set('[data-site="address"]', data.addressAr);
          set('[data-site="email"]', data.email);
          set('[data-site="emailHref"]', data.email ? `mailto:${data.email}` : '');
          set('[data-site="hours"]', data.workingHoursAr);

          if (Array.isArray(data.contacts) && data.contacts.length) {
            const primary = data.contacts[0];
            const digits = primary.phone.replace(/[^\d]/g, '');
            set('[data-site="primaryPhone"]', primary.phone);
            set(
              '[data-site="primaryWhatsapp"]',
              `https://wa.me/${digits}${primary.whatsappMessage ? `?text=${encodeURIComponent(primary.whatsappMessage)}` : ''}`,
            );
          }
        } catch {
          /* network blip — static fallback stays */
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --brand-red: #E0301E;
    --brand-orange: #EC7A2C;
    --brand-gold: #F2A93B;
    --brand-dark: #241310;
    --brand-gray: #58595B;
  }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Tajawal', system-ui, sans-serif;
  }
  h1, h2, h3, h4 {
    font-family: 'Cairo', system-ui, sans-serif;
    font-weight: 900;
    /* No negative tracking: Arabic is a connected script, so tightening it
       pulls joined letterforms into each other. Latin-first default, wrong here. */
    letter-spacing: normal;
  }
  /* background-clip:text paints only the glyphs, so a tight line box shears the
     descenders off gradient headings. inline-block + padding gives them room. */
  .shine-text {
    display: inline-block;
    padding-bottom: 0.12em;
  }

  /* ===== Reveal-on-scroll animations ===== */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.08s; }
  .reveal-delay-2 { transition-delay: 0.16s; }
  .reveal-delay-3 { transition-delay: 0.24s; }
  .reveal-delay-4 { transition-delay: 0.32s; }
  .reveal-delay-5 { transition-delay: 0.40s; }

  /* .reveal starts at opacity:0 and only the IntersectionObserver adds .in —
     so a JS failure would leave the whole page permanently invisible, and
     users who asked the OS for less motion still got every animation.
     This block is both the reduced-motion honour and the no-JS safety net. */
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
    .float-anim, .blob-anim, .shine-text, .pulse-ring::after { animation: none !important; }
    .tilt-card, .tilt-card:hover { transition: none !important; transform: none !important; }
    html { scroll-behavior: auto; }
  }

  /* ===== Continuous animations ===== */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  @keyframes blob {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(20px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }
  @keyframes shine {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(1.8); opacity: 0; }
  }
  @keyframes draw-line {
    from { stroke-dashoffset: 100; }
    to { stroke-dashoffset: 0; }
  }

  .float-anim { animation: float 6s ease-in-out infinite; }
  .blob-anim { animation: blob 14s ease-in-out infinite; }
  .shine-text {
    background: linear-gradient(90deg, #F2A93B 0%, #fff 50%, #F2A93B 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 4s linear infinite;
  }
  .pulse-ring::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    border: 2px solid currentColor;
    animation: pulse-ring 2.4s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
  }

  /* ===== Tilt on hover ===== */
  .tilt-card {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transform-style: preserve-3d;
  }
  .tilt-card:hover {
    transform: translateY(-6px) rotateX(2deg);
    box-shadow: 0 30px 60px -20px rgba(224, 48, 30, 0.25);
  }

  /* ===== Section dividers ===== */
  .grain {
    background-image:
      radial-gradient(circle at 1px 1px, rgba(0, 0, 0, 0.04) 1px, transparent 0);
    background-size: 24px 24px;
  }
</style>

<script>
  // Reveal-on-scroll
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      }
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
  );
  for (const el of document.querySelectorAll('.reveal')) io.observe(el);

  // Subtle tilt-on-mousemove for tilt-card elements
  for (const card of document.querySelectorAll<HTMLElement>('.tilt-card')) {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      card.style.transform = `translateY(-6px) rotateX(${-y * 4}deg) rotateY(${x * 4}deg)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  }
</script>
