# Production env — used by `pnpm build`.
# Assumes backend is reverse-proxied at /api on the same domain.
# If backend goes to a subdomain (e.g. api.deliverytamem.com), edit these
# then rebuild.
VITE_API_URL=https://backendtamem.deliverytamem.com/api/v1
VITE_WS_URL=https://backendtamem.deliverytamem.com
VITE_USE_MOCKS=false
# The Node.js backend + Socket.IO server isn't running yet (PHP shim only).
# Flip this to false the moment Node.js is enabled in hPanel.
VITE_DISABLE_SOCKET=true
