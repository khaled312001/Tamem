{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Tamem React Native (Expo) TSConfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "noEmit": true,
    "allowJs": true,
    "types": ["node"]
  }
}
