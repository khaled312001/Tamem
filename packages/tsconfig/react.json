{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Tamem React (Web) TSConfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "noEmit": true,
    "allowImportingTsExtensions": false
  }
}
