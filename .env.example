# ============================================
# Tamem Delivery — Environment Variables Template
# ============================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to git.

# ----- Backend (apps/backend) -----
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# MySQL — local dev (Hostinger VPS uses 127.0.0.1 in production)
DATABASE_URL="mysql://tamem:CHANGE_ME@localhost:3306/tamem"

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_LONG_RANDOM_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Google OAuth (for /auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps (geocoding + distance matrix)
GOOGLE_MAPS_API_KEY=

# WhatsApp Cloud API (optional in Phase 1 — deep-link is the fallback)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_NUMBER=+201XXXXXXXXX

# Firebase Cloud Messaging (push notifications)
FCM_SERVICE_ACCOUNT_JSON_PATH=./fcm-service-account.json

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4321

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=10485760

# Cash limit for drivers (in EGP)
DRIVER_CASH_LIMIT=1000

# ----- Dashboard (apps/dashboard) -----
VITE_API_URL=http://localhost:4000/api/v1
VITE_WS_URL=http://localhost:4000
VITE_USE_MOCKS=false

# ----- Mobile (apps/mobile) -----
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_WS_URL=http://localhost:4000
EXPO_PUBLIC_USE_MOCKS=false
EXPO_PUBLIC_TAMEM_WHATSAPP=+201XXXXXXXXX
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# ----- Landing (apps/landing) -----
PUBLIC_SITE_URL=https://tamem-delivery.com
PUBLIC_TAMEM_WHATSAPP=+201XXXXXXXXX
PUBLIC_PLAYSTORE_URL=
